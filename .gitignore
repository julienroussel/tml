# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
/.playwright/
/.playwright-mcp/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# PowerSync WASM assets (generated by postinstall)
/public/powersync

# llms.txt & llms-full.txt — derived from docs/**/*.md by scripts/generate-llms-txt.ts.
# Regenerated automatically by `prebuild` (and `predev`); kept out of git so PR diffs
# stay focused on the docs/*.md sources.
/public/llms.txt
/public/llms-full.txt

# PowerSync CLI link file (instance IDs; set via GitHub secrets/variables in CI)
/powersync/cli.yaml

# react-email dev server
.react-email/

# claude code generated artifacts
.claude/audit-*
.claude/review-*.json
.claude/*.lock
.claude/settings.local.json
/CLAUDE.local.md
.claude/worktrees

