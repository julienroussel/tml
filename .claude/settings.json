{
  "permissions": {
    "ask": [
      "Bash(pnpm db:migrate *)",
      "Bash(pnpm db:generate *)",
      "Bash(npx drizzle-kit migrate *)",
      "Bash(npx drizzle-kit push *)",
      "Bash(pnpm exec drizzle-kit migrate *)",
      "Bash(pnpm exec drizzle-kit push *)",
      "mcp__neon__run_sql",
      "mcp__neon__run_sql_transaction",
      "mcp__neon__reset_from_parent",
      "mcp__neon__delete_branch",
      "mcp__neon__delete_project",
      "mcp__neon__prepare_database_migration",
      "mcp__neon__complete_database_migration"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/edit-nudges.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/stop-validate.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.sh"
          }
        ]
      }
    ]
  }
}
