    "next-intl": "4.8.3",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "6.9.4",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "web-push": "3.6.7"
