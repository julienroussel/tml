{
  "name": "tml",
  "version": "0.1.0",
  "private": true,
  "description": "The Magic Lab",
  "type": "module",
  "homepage": "https://github.com/julienroussel/tml#readme",
  "bugs": {
    "url": "https://github.com/julienroussel/tml/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julienroussel/tml.git"
  },
  "author": "Julien Roussel",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "24.x",
