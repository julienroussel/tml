{
  "name": "tml",
  "version": "0.1.0",
  "private": true,
  "description": "The Magic Lab",
  "type": "module",
  "homepage": "https://github.com/julienroussel/tml#readme",
  "bugs": {
    "url": "https://github.com/julienroussel/tml/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/julienroussel/tml.git"
  },
  "author": "Julien Roussel",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "24.x",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev": "next dev --experimental-https",
    "build": "next build",
    "start": "next start",
    "lint": "ultracite check",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "tsc -b",
    "fix": "ultracite fix",
    "postinstall": "powersync-web copy-assets -o public && rm -rf public/powersync && mv public/@powersync public/powersync",
    "prepare": "lefthook install",
    "setup": "tsx scripts/setup.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "docs:generate": "tsx scripts/generate-docs.ts",
    "i18n:check": "tsx scripts/check-i18n.ts",
    "email:dev": "email dev --dir src/emails --port 3030",
    "screenshots": "tsx scripts/generate-screenshots.ts"
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@journeyapps/wa-sqlite": "1.5.0",
    "@neondatabase/auth": "0.2.0-beta.1",
    "@neondatabase/serverless": "1.0.2",
    "@powersync/common": "1.51.0",
    "@powersync/kysely-driver": "1.3.3",
    "@powersync/react": "1.10.0",
    "@powersync/web": "1.37.1",
    "@react-email/components": "1.0.11",
    "@react-email/render": "2.0.5",
    "@vercel/analytics": "2.0.1",
    "@vercel/firewall": "1.1.2",
    "@vercel/speed-insights": "2.0.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "drizzle-orm": "0.45.2",
    "drizzle-zod": "0.8.3",
    "lucide-react": "1.7.0",
    "next": "16.2.2",
    "next-intl": "4.9.0",
    "next-themes": "0.4.6",
    "radix-ui": "1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.72.1",
    "resend": "6.10.0",
    "server-only": "0.0.1",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "web-push": "3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@playwright/test": "1.59.1",
    "@react-email/preview-server": "5.2.10",
    "@tailwindcss/postcss": "4.2.2",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/culori": "4.0.1",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "babel-plugin-react-compiler": "1.0.0",
    "culori": "^4.0.2",
    "dotenv": "17.4.1",
    "drizzle-kit": "0.31.10",
    "jsdom": "29.0.2",
    "lefthook": "2.1.5",
    "react-email": "5.2.10",
    "shadcn": "4.1.2",
    "tailwindcss": "4.2.2",
    "tsx": "4.21.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "ultracite": "7.4.3",
    "vitest": "4.1.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@journeyapps/wa-sqlite",
      "@parcel/watcher",
      "@swc/core",
      "core-js",
      "esbuild",
      "lefthook"
    ],
    "overrides": {
      "zod": "$zod"
    },
    "packageExtensions": {
      "@neondatabase/auth": {
        "peerDependencies": {
          "lucide-react": "*"
        }
      }
    }
  }
}
